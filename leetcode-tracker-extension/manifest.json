{
  "manifest_version": 3,
  "name": "LeetCode Activity Tracker",
  "version": "1.0",
  "description": "Sends LeetCode login and submission activity to my app",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://leetcode.com/*"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/*"],
      "js": ["content.js"]
    }
  ]
}